# Keep build context lean and secret-free.
**/.env
**/.env.*
**/.git
**/.next
**/.turbo
**/.vercel
**/node_modules
**/__pycache__
**/.pytest_cache
**/.ruff_cache
**/.mypy_cache
**/.venv
**/dist
**/build
**/coverage
**/*.log

# Local SQLite snapshots — Railway uses managed Postgres.
apps/worker/fondok.db
apps/worker/*.db
apps/worker/*.sqlite
apps/worker/*.sqlite3

# Other apps not needed by the worker image. Keeps Railway's
# vulnerability scanner from inspecting the Next.js web app.
apps/web
docs
# evals/ INTENTIONALLY NOT EXCLUDED. The USALI rules catalog at
# evals/golden-set/usali-rules.csv is loaded at runtime by
# app.usali_rules.load_usali_rules() — without it every P&L scores
# applicable=0 / inconclusive (Sam QA 2026-06-29). Total evals/
# footprint is ~280 KB; the cost of including it is negligible.
package-lock.json
pnpm-lock.yaml

# IDE / OS noise
.DS_Store
.idea
.vscode

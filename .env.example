# Worker
DATABASE_URL=sqlite+aiosqlite:///./fondok.db
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=anthropic
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000
DEFAULT_DEAL_BUDGET_USD=20.0
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Web
NEXT_PUBLIC_WORKER_URL=http://localhost:8001
# Sentry (optional, off by default). When unset, Sentry is a no-op even if
# the optional @sentry/nextjs package is installed. Set this to enable
# browser + server error reporting from the Next.js web app. See DEPLOY.md
# "Sentry" for full setup steps.
NEXT_PUBLIC_SENTRY_DSN=

# Web — Clerk auth (optional). When NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is
# unset (or ends in `_dummy`), the app falls back to the demo persona
# "Eshan Mehta · Brookfield Real Estate" and the worker uses
# DEFAULT_TENANT_ID for every request. Set both keys to enable real auth +
# multi-tenant scoping via the X-Tenant-Id header. See DEPLOY.md
# "Enabling Clerk auth" for setup.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: external services
LLAMA_CLOUD_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_KMS_KEY_ID=
QDRANT_URL=
REDIS_URL=

# Optional: per-role model overrides
ANTHROPIC_ROUTER_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_EXTRACTOR_MODEL=claude-sonnet-4-6
ANTHROPIC_NORMALIZER_MODEL=claude-sonnet-4-6
ANTHROPIC_ANALYST_MODEL=claude-opus-4-7
ANTHROPIC_VARIANCE_MODEL=claude-sonnet-4-6
